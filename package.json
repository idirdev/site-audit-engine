  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "cli-table3": "^0.6.5",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "vitest": "^2.0.0"
  }
}
