{
  "name": "site-audit-engine",
  "version": "1.0.0",
  "description": "Audit any website for SEO, performance, accessibility, and security issues from the command line",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sae": "dist/cli/index.js",
    "site-audit": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
